# ── Vercel Blob Storage ────────────────────────────────────────────────────────
# Required when deploying to Vercel.
# Get this from: Vercel Dashboard → your project → Storage → Blob → .env.local
#
# When this variable is NOT set (e.g. local dev), the app uses the local
# ./data/ folder instead — no Blob account needed for development.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx
